# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5500/frontend
APP_URL=http://localhost:5000

# Database driver: 'mysql' (XAMPP local) or 'sqlite' (Render persistent disk)
DB_DRIVER=mysql

# MySQL (XAMPP) – only used when DB_DRIVER=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=meetspace_db

# Render persistent disk – only used when DB_DRIVER=sqlite
# Render sets DB_DISK_PATH=/var/data by default when you attach a disk
# DB_DISK_PATH=/var/data

# Security
JWT_SECRET=replace_with_strong_secret
JWT_EXPIRES_IN=24h
SESSION_SECRET=replace_with_session_secret

# Optional SMTP (email verification + password reset)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="MeetSpace <no-reply@meetspace.local>"
